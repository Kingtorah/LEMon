{
  "model": "ALED",
  "predict_af_depths": true,
  "transforms": {
    "pad": {
      "pad_input": false
    },
    "crop": {
      "crop_input": true,
      "crop_size": 608
    }
  },
  "batch_size_train": 4,
  "num_workers": 8,
  "accumulation_steps_train": 2,
  "dataset": {
    "name": "SLED",
    "path_train": "/path/to/the/preprocessed/dataset/train/",
    "path_val": "/path/to/the/preprocessed/dataset/val/",
    "train_is_zipped": true,
    "val_is_zipped": true,
    "train_subset_rule": "",
    "val_subset_rule": "(idx - 60) % 80 == 0"
  },
  "epochs": 50,
  "initial_learning_rate": 0.0001,
  "final_learning_rate": 0.0001,
  "weight_msg_epoch_0": 1.0,
  "losses_display_every_x": 20
}
